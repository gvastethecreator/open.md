{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "📥 deps",
            "type": "shell",
            "command": "npm",
            "args": [
                "install"
            ],
            "group": "none"
        },
        {
            "label": "⚡ web dev",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "dev"
            ],
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🖥️ app dev",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "tauri",
                "dev"
            ],
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🧪 front",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "test:frontend"
            ],
            "group": "test"
        },
        {
            "label": "🦀 rust",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "test:rust"
            ],
            "group": "test"
        },
        {
            "label": "🔎 check",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "check:frontend"
            ],
            "group": "test"
        },
        {
            "label": "✅ verify",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "verify"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "📦 build",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "tauri",
                "build"
            ],
            "dependsOn": [
                "✅ verify"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}