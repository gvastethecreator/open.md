{
  "name": "open-md",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "test:frontend": "vitest run",
    "check:frontend": "node ./scripts/validate-frontend.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "verify": "bun run check:frontend && bun run fmt:rust && bun run check:rust && bun run test:rust"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "jsdom": "^29.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "mermaid": "^11.13.0"
  }
}