{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMD",
  "version": "0.1.0",
  "identifier": "com.gvastethecreator.openmd",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenMD",
        "width": 900,
        "height": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Viewer",
        "mimeType": "text/markdown"
      },
      {
        "ext": [
          "txt"
        ],
        "name": "Text Document",
        "description": "Text Document",
        "role": "Viewer",
        "mimeType": "text/plain"
      }
    ]
  }
}